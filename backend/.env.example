# ── Grant Gni backend configuration ───────────────────────────────
# Copy this file to ".env" and fill in the values. NEVER commit ".env".

# Port the gateway listens on (the add-in defaults to https://localhost:3001).
PORT=3001

# Use HTTPS locally. Office add-ins run over HTTPS, and a browser will block
# an HTTPS task pane from calling an HTTP backend (mixed content). The office
# dev-cert tooling (office-addin-dev-certs) already generates localhost certs;
# point these at them, or generate your own. See V1_SETUP.md.
USE_HTTPS=true
# Absolute paths to your local dev certificate + key (PEM format).
SSL_CERT_PATH=
SSL_KEY_PATH=

# Comma-separated list of origins allowed to call this backend (CORS).
# The Word/Excel add-in is served from https://localhost:3000 in dev.
ALLOWED_ORIGINS=https://localhost:3000

# ── LLM provider (v1 = Gemini direct) ──────────────────────────────
# SAM: paste your Google Gemini API key here in the real .env file.
# Get one at https://aistudio.google.com/app/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=

# Optional: pin the Gemini API base. Leave default unless Google changes it.
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Automatic model fallback (resilience layer). If the requested model returns a
# 503 "high demand" / 429 / transient error, the backend retries, then falls back
# through this comma-separated chain. Keeps Review + chat working during spikes.
LLM_FALLBACK_MODELS=gemini-2.5-flash,gemini-flash-latest,gemini-2.5-flash-lite
LLM_RETRIES_PER_MODEL=2

# ── Embeddings (knowledge layer) — INDEPENDENT OF THE LLM ──────────
# This layer is fully decoupled from the chat/Review LLM above. Changing or
# swapping LLM_PROVIDER / the chat model has NO effect on the vectors in the
# vector DB. Only these EMBED_* settings define how text is embedded.
#
# Provider:
#   local  = deterministic, offline, no key (development / testing, lower quality)
#   gemini = real semantic embeddings using GEMINI_API_KEY (recommended for prod)
EMBED_PROVIDER=gemini
# Best-in-class text embedding model on GCP (top of the MTEB multilingual board).
# Alternatives: text-embedding-004 (older, 768-dim), gemini-embedding-2 (multimodal).
EMBED_MODEL=gemini-embedding-001
# Output dimensionality (Matryoshka). 768 / 1536 / 3072 supported; 1536 is a good
# quality/storage balance. Must match the dim the vector store was built with.
EMBED_DIM=1536
#
# IMPORTANT: the query embedding and the stored vectors MUST use the same
# EMBED_MODEL + EMBED_DIM. If you change either, re-run `npm run ingest` for the
# global store and re-upload tenant documents. The vector store records the model
# it was built with, and retrieval skips any store whose dim no longer matches.

# Model used by the Advisor (Review) to generate suggestions (an LLM, not an embedder).
ADVISOR_MODEL=gemini-flash-latest

# ── PRODUCTION: Qdrant + Vertex AI (Stage: real vector DB) ─────────
# Flip the whole knowledge layer from the legacy JSON files to Qdrant.
#   file   = legacy JSON store (default, dev)
#   qdrant = production vector DB
KB_BACKEND=qdrant

# Use Vertex AI for the LLM and embeddings (one service account, EU region).
LLM_PROVIDER=vertex
EMBED_PROVIDER=vertex

# GCP project + regions.
GCP_PROJECT=grant-gni
GCP_REGION=europe-west1
VERTEX_LOCATION=europe-west1
# The Ranking API (reranker) is addressed at "global".
VERTEX_RANK_LOCATION=global
VERTEX_RANK_MODEL=semantic-ranker-default-004
VERTEX_GEN_MODEL=gemini-2.5-flash

# Service-account key (Secret Manager secret "sa_key"). Provide ONE of:
#   SA_KEY = the JSON content (recommended on Cloud Run, from Secret Manager), or
#   GOOGLE_APPLICATION_CREDENTIALS = path to the JSON file (local dev).
# SA_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa_key.json

# Qdrant Cloud (cluster in europe-west3 / Frankfurt). From Secret Manager.
QDRANT_URL=
QDRANT_API_KEY=
# Collection names (defaults are fine).
# QDRANT_COLLECTION_PUBLIC=kb_public
# QDRANT_COLLECTION_IP=kb_ip
# QDRANT_COLLECTION_CLIENTS=kb_clients

# ── Minimal auth (binds tenant server-side; protects tier-2/tier-3) ─
# Turn on once clients have keys. When off, tenantId is taken from the request
# (dev only, spoofable).
AUTH_ENABLED=false
# JSON map of issued client key -> tenantId (from Secret Manager).
# TENANT_KEYS={"sk_demo_xxx":"demo"}
# Bearer token required for /api/admin/* (ingestion/bootstrap).
# ADMIN_TOKEN=
